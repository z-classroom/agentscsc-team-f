# --- LLM CONFIGURATION ---
# Options: mock, openai, anthropic, gemini
# you may use local open weight model like deepseek, no key is required.
LLM_PROVIDER=openai

# --- API KEYS ---
# Do NOT commit your actual keys to GitHub! 
# Get your key at: 
OPENAI_API_KEY=

# Optional: If you use other providers
ANTHROPIC_API_KEY=your_anthropic_key_here
GOOGLE_API_KEY=your_gemini_key_here

# --- MODEL SETTINGS ---
# Example: gpt-4o-mini, gpt-3.5-turbo, or mock-model
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.7
